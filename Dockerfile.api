FROM node:24-alpine AS base
WORKDIR /app

FROM base AS builder
COPY package.json package-lock.json turbo.json tsconfig.base.json ./
COPY apps/api/package.json apps/api/
COPY apps/rule-admin/package.json apps/rule-admin/
COPY apps/web/package.json apps/web/
COPY apps/word-addin/package.json apps/word-addin/
COPY apps/workers/package.json apps/workers/
COPY packages/db/package.json packages/db/
COPY packages/diff-engine/package.json packages/diff-engine/
COPY packages/doc-parser/package.json packages/doc-parser/
COPY packages/llm-gateway/package.json packages/llm-gateway/
COPY packages/rules-engine/package.json packages/rules-engine/
COPY packages/shared/package.json packages/shared/
COPY packages/ui/package.json packages/ui/

RUN npm install

COPY taxonomy.yaml ./
COPY packages/ packages/
COPY apps/api/ apps/api/

RUN npx prisma generate --schema=packages/db/prisma/schema.prisma
RUN npx turbo build --filter=@clinscriptum/api
RUN cp apps/api/src/data/*.yaml apps/api/dist/data/ 2>/dev/null || true

FROM base AS runner
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages ./packages
COPY --from=builder /app/apps/api ./apps/api
COPY --from=builder /app/taxonomy.yaml ./

EXPOSE 4000
ENV NODE_ENV=production
CMD ["node", "apps/api/dist/index.js"]
