{
  "name": "@clinscriptum/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./fact-extraction": {
      "types": "./src/fact-extraction-core.ts",
      "default": "./dist/fact-extraction-core.js"
    },
    "./soa-detection": {
      "types": "./src/soa-detection-core.ts",
      "default": "./dist/soa-detection-core.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clinscriptum/db": "*",
    "@clinscriptum/rules-engine": "*",
    "@clinscriptum/llm-gateway": "*"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
