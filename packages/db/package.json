{
  "name": "@clinscriptum/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "seed": "tsx --env-file=../../.env src/seed.ts",
    "seed:prompts": "tsx --env-file=../../.env src/seed-prompts.ts",
    "seed:taxonomy": "tsx --env-file=../../.env src/seed-taxonomy.ts",
    "seed:facts": "tsx --env-file=../../.env src/seed-fact-registry.ts",
    "seed:all": "tsx --env-file=../../.env src/seed.ts && tsx --env-file=../../.env src/seed-taxonomy.ts && tsx --env-file=../../.env src/seed-fact-registry.ts && tsx --env-file=../../.env src/seed-prompts.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6",
    "bcryptjs": "^2.4.3",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2",
    "prisma": "^6",
    "tsx": "^4",
    "typescript": "^5"
  }
}
