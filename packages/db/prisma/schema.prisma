generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant ────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  plan      Plan     @default(basic)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                  User[]
  studies                Study[]
  config                 TenantConfig?
  classificationFewShots ClassificationFewShot[]

  @@map("tenants")
}

model TenantConfig {
  id                      String   @id @default(uuid()) @db.Uuid
  tenantId                String   @unique @map("tenant_id") @db.Uuid
  excludedSectionPrefixes String[] @default(["overview", "admin", "appendix", "ip.preclinical_clinical_data"]) @map("excluded_section_prefixes")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_configs")
}

enum Plan {
  basic
  extended
}

// ─── Users & Auth ────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         UserRole @default(writer)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens  RefreshToken[]
  findingReviews FindingReview[]

  goldenSamplesCreated      GoldenSample[]             @relation("GoldenSampleCreator")
  goldenStageReviews        GoldenSampleStageStatus[]  @relation("StageReviewer")
  goldenStageApprovals      GoldenSampleStageStatus[]  @relation("StageApprover")
  evaluationRunsCreated     EvaluationRun[]
  correctionRecords         CorrectionRecord[]
  correctionRecommendations CorrectionRecommendation[] @relation("RecommendationReviewer")
  approvalRequests          ApprovalRequest[]          @relation("ApprovalRequester")
  approvalReviews           ApprovalRequest[]          @relation("ApprovalReviewer")
  classificationFewShots    ClassificationFewShot[]    @relation("ClassificationFewShotCreator")

  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  writer
  qc_operator
  findings_reviewer
  rule_admin
  rule_approver
  tenant_admin
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Studies & Documents ─────────────────────────────────────

model Study {
  id                     String     @id @default(uuid()) @db.Uuid
  tenantId               String     @map("tenant_id") @db.Uuid
  title                  String
  sponsor                String?
  drug                   String?
  therapeuticArea        String?    @map("therapeutic_area")
  protocolTitle          String?    @map("protocol_title")
  phase                  String     @default("")
  operatorReviewEnabled    Boolean    @default(false) @map("operator_review_enabled")
  llmThinkingEnabled       Boolean    @default(false) @map("llm_thinking_enabled")
  excludedSectionPrefixes  String[]   @default([]) @map("excluded_section_prefixes")
  auditMode                String     @default("auto") @map("audit_mode")
  crossCheckPairs          Json?      @map("cross_check_pairs") @db.JsonB
  createdAt                DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents      Document[]
  processingRuns ProcessingRun[]

  @@index([tenantId])
  @@map("studies")
}


model Document {
  id        String       @id @default(uuid()) @db.Uuid
  studyId   String       @map("study_id") @db.Uuid
  type      DocumentType
  title     String
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  study    Study             @relation(fields: [studyId], references: [id], onDelete: Cascade)
  versions DocumentVersion[]

  @@index([studyId])
  @@map("documents")
}

enum DocumentType {
  protocol
  icf
  ib
  csr
}

model DocumentVersion {
  id            String                @id @default(uuid()) @db.Uuid
  documentId    String                @map("document_id") @db.Uuid
  versionNumber Int                   @map("version_number")
  versionLabel  String?               @map("version_label")
  fileUrl       String                @map("file_url")
  status        DocumentVersionStatus @default(uploading)
  isCurrent     Boolean               @default(false) @map("is_current")
  digitalTwin   Json?                 @map("digital_twin") @db.JsonB
  createdAt     DateTime              @default(now()) @map("created_at")

  document        Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sections        Section[]
  facts           Fact[]
  findings        Finding[]
  processingRuns  ProcessingRun[]
  soaTables       SoaTable[]
  generatedDocs   GeneratedDoc[]
  tuningSessions  TuningSession[]
  findingReviews  FindingReview[]

  goldenSampleDocuments GoldenSampleDocument[]
  correctionRecords     CorrectionRecord[]

  @@unique([documentId, versionNumber])
  @@index([documentId])
  @@map("document_versions")
}

enum DocumentVersionStatus {
  uploading
  parsing
  classifying_sections
  extracting_facts
  detecting_soa
  ready
  intra_audit
  inter_audit
  impact_assessment
  parsed
  error
}

// ─── Sections & Content ──────────────────────────────────────

model Section {
  id              String        @id @default(uuid()) @db.Uuid
  docVersionId    String        @map("doc_version_id") @db.Uuid
  title           String
  standardSection String?       @map("standard_section")
  confidence      Float         @default(0)
  classifiedBy    String?       @map("classified_by")
  algoSection     String?       @map("algo_section")
  algoConfidence  Float         @default(0) @map("algo_confidence")
  llmSection      String?       @map("llm_section")
  llmConfidence   Float         @default(0) @map("llm_confidence")
  level           Int
  order           Int
  structureStatus      SectionStatus @default(not_validated) @map("structure_status")
  classificationStatus SectionStatus @default(not_validated) @map("classification_status")
  structureComment      String?       @map("structure_comment")
  classificationComment String?       @map("classification_comment")
  isFalseHeading  Boolean       @default(false) @map("is_false_heading")
  sourceAnchor    Json          @map("source_anchor") @db.JsonB

  docVersion    DocumentVersion @relation(fields: [docVersionId], references: [id], onDelete: Cascade)
  contentBlocks ContentBlock[]

  @@index([docVersionId])
  @@map("sections")
}

enum SectionStatus {
  validated
  not_validated
  requires_rework
}

model ContentBlock {
  id           String           @id @default(uuid()) @db.Uuid
  sectionId    String           @map("section_id") @db.Uuid
  type         ContentBlockType
  content      String
  rawHtml      String?          @map("raw_html")
  order        Int
  sourceAnchor Json             @map("source_anchor") @db.JsonB
  tableAst     Json?            @map("table_ast") @db.JsonB

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@map("content_blocks")
}

enum ContentBlockType {
  paragraph
  table
  table_cell
  footnote
  list
  image
}

// ─── Facts ───────────────────────────────────────────────────

model Fact {
  id               String     @id @default(uuid()) @db.Uuid
  docVersionId     String     @map("doc_version_id") @db.Uuid
  factKey          String     @map("fact_key")
  factCategory     String     @map("fact_category")
  description      String     @default("")
  value            String
  /// Canonical normalised form of `value` (Phase 1 of fact-extraction roadmap).
  /// Built by rules-engine `canonicalize(factKey, value)`; equality on this
  /// field is what voting and contradiction detection compare.
  canonicalValue          String?  @map("canonical_value")
  /// `standardSection` of the section that produced the strongest source
  /// occurrence. Free-form string to stay independent of section taxonomy
  /// changes done in parallel work.
  standardSectionCode     String?  @map("standard_section_code")
  /// Number of distinct source occurrences contributing to this fact after
  /// `aggregateByCanonical` voting. Defaults to 1 so that pre-Phase-1 rows
  /// remain valid.
  sourceCount             Int      @default(1) @map("source_count")
  manualValue      String?    @map("manual_value")
  confidence       Float      @default(0)
  factClass        FactClass  @map("fact_class")
  sources          Json       @db.JsonB
  hasContradiction Boolean    @default(false) @map("has_contradiction")
  status           FactStatus @default(extracted)
  deterministicValue      String?  @map("deterministic_value")
  deterministicConfidence Float    @default(0) @map("deterministic_confidence")
  llmValue                String?  @map("llm_value")
  llmConfidence           Float    @default(0) @map("llm_confidence")
  qaValue                 String?  @map("qa_value")
  qaConfidence            Float    @default(0) @map("qa_confidence")
  variants                Json     @default("[]") @db.JsonB

  docVersion DocumentVersion @relation(fields: [docVersionId], references: [id], onDelete: Cascade)

  @@index([docVersionId])
  @@map("facts")
}

enum FactClass {
  general
  phase_specific
}

enum FactStatus {
  extracted
  verified
  validated
  deferred
  not_found
  rejected
}

// ─── Findings ────────────────────────────────────────────────

model Finding {
  id              String         @id @default(uuid()) @db.Uuid
  docVersionId    String         @map("doc_version_id") @db.Uuid
  type            FindingType
  description     String
  suggestion      String?
  sourceRef       Json           @map("source_ref") @db.JsonB
  status          FindingStatus  @default(pending)
  severity        AuditSeverity?
  auditCategory   String?        @map("audit_category")
  issueType       String?        @map("issue_type")
  issueFamily     String?        @map("issue_family")
  anchorZone      String?        @map("anchor_zone")
  targetZone      String?        @map("target_zone")
  qaVerified       Boolean        @default(false) @map("qa_verified")
  hiddenByReviewer Boolean        @default(false) @map("hidden_by_reviewer")
  originalSeverity AuditSeverity? @map("original_severity")
  reviewerNote     String?        @map("reviewer_note")
  extraAttributes  Json           @default("{}") @map("extra_attributes") @db.JsonB
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  docVersion DocumentVersion @relation(fields: [docVersionId], references: [id], onDelete: Cascade)

  @@index([docVersionId])
  @@index([docVersionId, type])
  @@index([docVersionId, severity])
  @@index([docVersionId, auditCategory])
  @@index([docVersionId, status])
  @@map("findings")
}

enum FindingType {
  editorial
  semantic
  intra_audit
  inter_audit
}

enum FindingStatus {
  pending
  confirmed
  rejected
  resolved
  false_positive
}

enum AuditSeverity {
  critical
  high
  medium
  low
  info
}

// ─── Processing Pipeline ─────────────────────────────────────

model ProcessingRun {
  id               String              @id @default(uuid()) @db.Uuid
  studyId          String              @map("study_id") @db.Uuid
  docVersionId     String              @map("doc_version_id") @db.Uuid
  type             ProcessingRunType
  status           ProcessingRunStatus @default(queued)
  ruleSetVersionId String?             @map("rule_set_version_id") @db.Uuid
  ruleSetBundleId  String?             @map("rule_set_bundle_id") @db.Uuid
  attemptNumber    Int                 @default(1) @map("attempt_number")
  maxAttempts      Int                 @default(3) @map("max_attempts")
  lastError        String?             @map("last_error")
  retriedFromId    String?             @map("retried_from_id") @db.Uuid
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  study          Study            @relation(fields: [studyId], references: [id], onDelete: Cascade)
  docVersion     DocumentVersion  @relation(fields: [docVersionId], references: [id], onDelete: Cascade)
  ruleSetVersion RuleSetVersion?  @relation(fields: [ruleSetVersionId], references: [id])
  ruleSetBundle  RuleSetBundle?   @relation(fields: [ruleSetBundleId], references: [id])
  steps          ProcessingStep[]

  @@index([studyId])
  @@index([docVersionId])
  @@map("processing_runs")
}

enum ProcessingRunType {
  section_classification
  fact_extraction
  soa_detection
  intra_doc_audit
  inter_doc_audit
  icf_generation
  csr_generation
  version_comparison
}

enum ProcessingRunStatus {
  queued
  running
  completed
  failed
}

model ProcessingStep {
  id              String               @id @default(uuid()) @db.Uuid
  processingRunId String               @map("processing_run_id") @db.Uuid
  level           PipelineLevel
  status          ProcessingStepStatus @default(pending)
  result            Json?                @db.JsonB
  llmConfigSnapshot Json?                @map("llm_config_snapshot") @db.JsonB
  ruleSnapshot      Json?                @map("rule_snapshot") @db.JsonB
  attemptNumber     Int                  @default(1) @map("attempt_number")
  idempotencyKey    String?              @map("idempotency_key")
  startedAt       DateTime?            @map("started_at")
  completedAt     DateTime?            @map("completed_at")

  processingRun ProcessingRun @relation(fields: [processingRunId], references: [id], onDelete: Cascade)

  @@index([processingRunId])
  @@map("processing_steps")
}

enum PipelineLevel {
  deterministic
  llm_check
  llm_qa
  operator_review
  user_validation
}

enum ProcessingStepStatus {
  pending
  running
  completed
  skipped
  failed
}

// ─── SOA (Schedule of Activities) ────────────────────────

model SoaTable {
  id                  String          @id @default(uuid()) @db.Uuid
  docVersionId        String          @map("doc_version_id") @db.Uuid
  sourceBlockId       String?         @map("source_block_id") @db.Uuid
  /// All ContentBlock IDs that contributed to this SoaTable. When a Word
  /// table is split across two `<w:tbl>` parts with a repeated header
  /// (continuation), the detector merges them and lists both block IDs
  /// here. `sourceBlockId` is kept as the first element for backward
  /// compatibility with consumers that read a single block.
  sourceBlockIds      Json            @default("[]") @map("source_block_ids") @db.JsonB
  title               String          @default("")
  soaScore            Float           @default(0) @map("soa_score")
  status              SoaStatus       @default(detected)
  orientation         SoaOrientation  @default(visits_cols)
  orientationConflict Boolean         @default(false) @map("orientation_conflict")
  /// Highest pipeline level this SoA table has been verified at:
  /// `deterministic` (rules only), `llm_check` (LLM agreed), `llm_qa`
  /// (LLM disagreed and a QA round was run). Drives confidence
  /// indicators in the UI.
  verificationLevel   SoaVerificationLevel @default(deterministic) @map("verification_level")
  /// Confidence reported by the LLM Check step (0..1). Null when the
  /// LLM step has not run.
  llmConfidence       Float?          @map("llm_confidence")
  headerData          Json            @map("header_data") @db.JsonB
  rawMatrix           Json            @map("raw_matrix") @db.JsonB
  /// Raw drawings extracted from word/document.xml that overlay this SoA
  /// table (arrows, lines, brackets). Each item: { type, position: {xEmu, yEmu, cxEmu, cyEmu}, direction? }.
  /// Used by the UI to render an SVG overlay.
  drawings            Json            @default("[]") @db.JsonB
  /// EMU-bounding-boxes of cells in this SoA table after canonicalization
  /// (visits-cols layout). Shape: (CellRect | null)[][]. Populated from
  /// extractTableGeometry at detect time. Used together with `drawings`
  /// to render arrows over cells in the UI without re-parsing the DOCX.
  cellGeometry        Json?           @map("cell_geometry") @db.JsonB
  createdAt           DateTime        @default(now()) @map("created_at")

  docVersion       DocumentVersion     @relation(fields: [docVersionId], references: [id], onDelete: Cascade)
  cells            SoaCell[]
  soaFootnotes     SoaFootnote[]
  footnoteAnchors  SoaFootnoteAnchor[]

  @@index([docVersionId])
  @@map("soa_tables")
}

model SoaCell {
  id              String  @id @default(uuid()) @db.Uuid
  soaTableId      String  @map("soa_table_id") @db.Uuid
  rowIndex        Int     @map("row_index")
  colIndex        Int     @map("col_index")
  procedureName   String  @map("procedure_name")
  visitName       String  @map("visit_name")
  rawValue        String  @default("") @map("raw_value")
  normalizedValue String  @default("") @map("normalized_value")
  manualValue     String? @map("manual_value")
  confidence      Float   @default(1.0)
  /// Sources contributing to the cell's mark — any of 'text', 'arrow',
  /// 'line', 'bracket'. 'text' means the X/dash came from the cell text;
  /// the others mean it was inferred from a graphic element overlaying the cell.
  markerSources   Json    @default("[\"text\"]") @db.JsonB @map("marker_sources")

  soaTable        SoaTable            @relation(fields: [soaTableId], references: [id], onDelete: Cascade)
  footnoteAnchors SoaFootnoteAnchor[]

  @@unique([soaTableId, rowIndex, colIndex])
  @@index([soaTableId])
  @@map("soa_cells")
}

enum SoaStatus {
  detected
  validated
  not_soa
}

enum SoaOrientation {
  visits_cols
  visits_rows
  unknown
}

enum SoaVerificationLevel {
  deterministic
  llm_check
  llm_qa
}

enum SoaFootnoteSource {
  detected
  manual
}

enum SoaFootnoteAnchorTarget {
  cell
  row
  col
}

model SoaFootnote {
  id          String            @id @default(uuid()) @db.Uuid
  soaTableId  String            @map("soa_table_id") @db.Uuid
  marker      String
  markerOrder Int               @map("marker_order")
  text        String            @default("")
  source      SoaFootnoteSource @default(detected)
  createdAt   DateTime          @default(now()) @map("created_at")

  soaTable SoaTable            @relation(fields: [soaTableId], references: [id], onDelete: Cascade)
  anchors  SoaFootnoteAnchor[]

  @@unique([soaTableId, marker])
  @@index([soaTableId])
  @@map("soa_footnotes")
}

model SoaFootnoteAnchor {
  id         String                  @id @default(uuid()) @db.Uuid
  footnoteId String                  @map("footnote_id") @db.Uuid
  soaTableId String                  @map("soa_table_id") @db.Uuid
  targetType SoaFootnoteAnchorTarget @map("target_type")
  cellId     String?                 @map("cell_id") @db.Uuid
  rowIndex   Int?                    @map("row_index")
  colIndex   Int?                    @map("col_index")
  confidence Float                   @default(1.0)
  source     SoaFootnoteSource       @default(detected)

  footnote SoaFootnote @relation(fields: [footnoteId], references: [id], onDelete: Cascade)
  soaTable SoaTable    @relation(fields: [soaTableId], references: [id], onDelete: Cascade)
  cell     SoaCell?    @relation(fields: [cellId], references: [id], onDelete: Cascade)

  @@unique([footnoteId, targetType, cellId, rowIndex, colIndex])
  @@index([footnoteId])
  @@index([soaTableId, targetType])
  @@index([cellId])
  @@map("soa_footnote_anchors")
}

// ─── Rule Set Bundles ────────────────────────────────────────

model RuleSetBundle {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid
  name        String
  description String?
  isActive    Boolean  @default(false) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  entries        RuleSetBundleEntry[]
  processingRuns ProcessingRun[]

  @@index([tenantId])
  @@map("rule_set_bundles")
}

model RuleSetBundleEntry {
  id               String @id @default(uuid()) @db.Uuid
  bundleId         String @map("bundle_id") @db.Uuid
  ruleSetVersionId String @map("rule_set_version_id") @db.Uuid

  bundle         RuleSetBundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  ruleSetVersion RuleSetVersion @relation(fields: [ruleSetVersionId], references: [id], onDelete: Cascade)

  @@unique([bundleId, ruleSetVersionId])
  @@index([bundleId])
  @@map("rule_set_bundle_entries")
}

// ─── Rule Sets ───────────────────────────────────────────────

model RuleSet {
  id        String      @id @default(uuid()) @db.Uuid
  tenantId  String?     @map("tenant_id") @db.Uuid
  name      String
  type      RuleSetType
  createdAt DateTime    @default(now()) @map("created_at")

  versions RuleSetVersion[]

  @@map("rule_sets")
}

enum RuleSetType {
  section_classification
  section_classification_qa
  fact_extraction
  fact_extraction_qa
  soa_detection
  soa_detection_qa
  intra_audit
  intra_audit_qa
  inter_audit
  inter_audit_qa
  fact_audit_intra
  fact_audit_intra_qa
  fact_audit_inter
  fact_audit_inter_qa
  generation
  generation_qa
  impact_analysis
  impact_analysis_qa
  change_classification
  change_classification_qa
  correction_recommend
  soa_identification
  audit
  fact_section_priors
  fact_anchors
  confidence_calibration
}

model RuleSetVersion {
  id          String   @id @default(uuid()) @db.Uuid
  ruleSetId   String   @map("rule_set_id") @db.Uuid
  version     Int
  description String?
  isActive    Boolean  @default(false) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  ruleSet        RuleSet              @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)
  rules          Rule[]
  processingRuns ProcessingRun[]
  evaluationRuns EvaluationRun[]
  bundleEntries  RuleSetBundleEntry[]

  @@unique([ruleSetId, version])
  @@map("rule_set_versions")
}

model Rule {
  id               String        @id @default(uuid()) @db.Uuid
  ruleSetVersionId String        @map("rule_set_version_id") @db.Uuid
  name             String
  pattern          String
  config           Json          @default("{}") @db.JsonB
  documentType     DocumentType? @map("document_type")
  stage            String?
  subStage         RuleSubStage? @map("sub_stage")
  promptTemplate   String?       @map("prompt_template")
  isEnabled        Boolean       @default(true) @map("is_enabled")
  requiresFacts    Boolean       @default(false) @map("requires_facts")
  requiresSoa      Boolean       @default(false) @map("requires_soa")
  order            Int           @default(0)

  ruleSetVersion RuleSetVersion @relation(fields: [ruleSetVersionId], references: [id], onDelete: Cascade)

  @@index([ruleSetVersionId])
  @@map("rules")
}

enum RuleSubStage {
  analysis
  qa
  self_check
  cross_check
  editorial
}

// ─── Document Templates ───────────────────────────────────────

model DocTemplate {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @map("tenant_id") @db.Uuid
  name      String
  docType   DocumentType @map("doc_type")
  sections  Json         @db.JsonB
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("doc_templates")
}

// ─── Generated Documents ──────────────────────────────────────

model GeneratedDoc {
  id                String             @id @default(uuid()) @db.Uuid
  protocolVersionId String             @map("protocol_version_id") @db.Uuid
  templateId        String?            @map("template_id") @db.Uuid
  docType           DocumentType       @map("doc_type")
  status            GeneratedDocStatus @default(generating)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  protocolVersion DocumentVersion       @relation(fields: [protocolVersionId], references: [id], onDelete: Cascade)
  sections        GeneratedDocSection[]
  tuningSessions  TuningSession[]

  @@index([protocolVersionId])
  @@map("generated_docs")
}

enum GeneratedDocStatus {
  generating
  qa_checking
  completed
  failed
}

model GeneratedDocSection {
  id              String                    @id @default(uuid()) @db.Uuid
  generatedDocId  String                    @map("generated_doc_id") @db.Uuid
  title           String
  standardSection String?                   @map("standard_section")
  order           Int
  content         String                    @default("")
  status          GeneratedDocSectionStatus @default(pending)
  qaFindings      Json                      @default("[]") @map("qa_findings") @db.JsonB

  generatedDoc GeneratedDoc @relation(fields: [generatedDocId], references: [id], onDelete: Cascade)

  @@index([generatedDocId])
  @@map("generated_doc_sections")
}

enum GeneratedDocSectionStatus {
  pending
  generating
  qa_checking
  completed
  skipped
  failed
}

// ─── Finding Reviews ─────────────────────────────────────────

model FindingReview {
  id                String              @id @default(uuid()) @db.Uuid
  tenantId          String              @map("tenant_id") @db.Uuid
  docVersionId      String              @map("doc_version_id") @db.Uuid
  auditType         FindingType         @map("audit_type")
  protocolVersionId String?             @map("protocol_version_id") @db.Uuid
  reviewerId        String?             @map("reviewer_id") @db.Uuid
  status            FindingReviewStatus @default(pending)
  createdAt         DateTime            @default(now()) @map("created_at")
  publishedAt       DateTime?           @map("published_at")

  docVersion DocumentVersion @relation(fields: [docVersionId], references: [id], onDelete: Cascade)
  reviewer   User?           @relation(fields: [reviewerId], references: [id])
  logs       FindingReviewLog[]

  @@unique([docVersionId, auditType])
  @@index([tenantId])
  @@index([status])
  @@map("finding_reviews")
}

enum FindingReviewStatus {
  pending
  in_review
  published
}

model FindingReviewLog {
  id            String   @id @default(uuid()) @db.Uuid
  reviewId      String   @map("review_id") @db.Uuid
  findingId     String   @map("finding_id") @db.Uuid
  reviewerId    String   @map("reviewer_id") @db.Uuid
  action        String
  previousValue String?  @map("previous_value")
  newValue      String?  @map("new_value")
  createdAt     DateTime @default(now()) @map("created_at")

  review FindingReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([findingId])
  @@map("finding_review_logs")
}

// ─── Word Add-in Sessions ────────────────────────────────────

model WordSession {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  context   Json     @db.JsonB
  exchanged Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("word_sessions")
}

// ─── Quality Tuning ──────────────────────────────────────────

model TuningSession {
  id           String              @id @default(uuid()) @db.Uuid
  tenantId     String              @map("tenant_id") @db.Uuid
  userId       String              @map("user_id") @db.Uuid
  docVersionId String              @map("doc_version_id") @db.Uuid
  type         TuningType
  status       TuningSessionStatus @default(processing)
  isGoldenSet  Boolean             @default(false) @map("is_golden_set")
  stats        Json                @default("{}") @db.JsonB
  createdAt    DateTime            @default(now()) @map("created_at")
  completedAt  DateTime?           @map("completed_at")

  generatedDocId String?  @map("generated_doc_id") @db.Uuid

  docVersion         DocumentVersion    @relation(fields: [docVersionId], references: [id], onDelete: Cascade)
  generatedDoc       GeneratedDoc?      @relation(fields: [generatedDocId], references: [id], onDelete: SetNull)
  sectionVerdicts    SectionVerdict[]
  factVerdicts       FactVerdict[]
  soaVerdicts        SoaVerdict[]
  generationVerdicts GenerationVerdict[]

  @@index([tenantId])
  @@index([docVersionId])
  @@map("tuning_sessions")
}

enum TuningType {
  section_classification
  fact_extraction
  soa_detection
  icf_generation
}

enum TuningSessionStatus {
  processing
  pending_review
  in_review
  completed
}

model SectionVerdict {
  id                String    @id @default(uuid()) @db.Uuid
  tuningSessionId   String    @map("tuning_session_id") @db.Uuid
  sectionId         String    @map("section_id") @db.Uuid
  algoResult        String?   @map("algo_result")
  algoConfidence    Float     @default(0) @map("algo_confidence")
  llmResult         String?   @map("llm_result")
  llmConfidence     Float     @default(0) @map("llm_confidence")
  auditorChoice     String?   @map("auditor_choice")
  auditorAgreedWith String?   @map("auditor_agreed_with")
  comment           String?
  reviewedAt        DateTime? @map("reviewed_at")

  tuningSession TuningSession @relation(fields: [tuningSessionId], references: [id], onDelete: Cascade)

  @@index([tuningSessionId])
  @@map("section_verdicts")
}

model FactVerdict {
  id              String    @id @default(uuid()) @db.Uuid
  tuningSessionId String    @map("tuning_session_id") @db.Uuid
  factId          String?   @map("fact_id") @db.Uuid
  factKey         String    @map("fact_key")
  llmValue        String?   @map("llm_value")
  llmConfidence   Float     @default(0) @map("llm_confidence")
  isCorrect       Boolean?  @map("is_correct")
  auditorValue    String?   @map("auditor_value")
  comment         String?
  reviewedAt      DateTime? @map("reviewed_at")

  tuningSession TuningSession @relation(fields: [tuningSessionId], references: [id], onDelete: Cascade)

  @@index([tuningSessionId])
  @@map("fact_verdicts")
}

model SoaVerdict {
  id                 String    @id @default(uuid()) @db.Uuid
  tuningSessionId    String    @map("tuning_session_id") @db.Uuid
  soaTableId         String?   @map("soa_table_id") @db.Uuid
  isCorrectDetection Boolean?  @map("is_correct_detection")
  missedTables       Json      @default("[]") @db.JsonB
  falsePositives     Json      @default("[]") @db.JsonB
  cellVerdicts       Json      @default("[]") @db.JsonB
  comment            String?
  reviewedAt         DateTime? @map("reviewed_at")

  tuningSession TuningSession @relation(fields: [tuningSessionId], references: [id], onDelete: Cascade)

  @@index([tuningSessionId])
  @@map("soa_verdicts")
}

model GenerationVerdict {
  id                    String    @id @default(uuid()) @db.Uuid
  tuningSessionId       String    @map("tuning_session_id") @db.Uuid
  generatedDocSectionId String    @map("generated_doc_section_id") @db.Uuid
  sectionTitle          String    @default("") @map("section_title")
  standardSection       String?   @map("standard_section")
  rating                Int       @default(0)
  comment               String?
  reviewedAt            DateTime? @map("reviewed_at")

  tuningSession TuningSession @relation(fields: [tuningSessionId], references: [id], onDelete: Cascade)

  @@index([tuningSessionId])
  @@map("generation_verdicts")
}

// ─── LLM Configuration ──────────────────────────────────────

model LlmConfig {
  id                String          @id @default(uuid()) @db.Uuid
  tenantId          String?         @map("tenant_id") @db.Uuid
  name              String
  taskId            String          @map("task_id")
  provider          String
  baseUrl           String          @default("") @map("base_url")
  apiKey            String          @default("") @map("api_key")
  model             String
  temperature       Float           @default(0.1)
  maxOutputTokens   Int             @default(2048) @map("max_output_tokens")
  maxInputTokens    Int             @default(16000) @map("max_input_tokens")
  contextStrategy   ContextStrategy @default(chunk) @map("context_strategy")
  chunkSizeChars    Int?            @map("chunk_size_chars")
  chunkOverlapChars Int?            @map("chunk_overlap_chars")
  modelWindowChars  Int?            @map("model_window_chars")
  rateLimit         Int?            @map("rate_limit")
  timeoutMs         Int?            @map("timeout_ms")
  coldStartMs       Int?            @map("cold_start_ms")
  reasoningMode     ReasoningMode   @default(DISABLED) @map("reasoning_mode")
  costPerInputKTokens  Float?      @map("cost_per_input_k_tokens")
  costPerOutputKTokens Float?      @map("cost_per_output_k_tokens")
  isActive          Boolean         @default(true) @map("is_active")
  isDefault         Boolean         @default(false) @map("is_default")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  evaluationRuns EvaluationRun[]

  @@index([taskId])
  @@map("llm_configs")
}

enum ContextStrategy {
  chunk
  multi_chunk
  full_document
  multi_document
}

enum ReasoningMode {
  DISABLED
  ENABLED_HIDDEN
}

// ─── Golden Dataset ─────────────────────────────────────────

model GoldenSample {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  name        String
  description String?
  sampleType  GoldenSampleType @map("sample_type")
  createdById String           @map("created_by_id") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  createdBy     User                      @relation("GoldenSampleCreator", fields: [createdById], references: [id])
  documents     GoldenSampleDocument[]
  stageStatuses GoldenSampleStageStatus[]
  evaluationResults EvaluationResult[]

  @@index([tenantId])
  @@map("golden_samples")
}

enum GoldenSampleType {
  single_document
  multi_document
}

model GoldenSampleDocument {
  id              String       @id @default(uuid()) @db.Uuid
  goldenSampleId  String       @map("golden_sample_id") @db.Uuid
  documentVersionId String     @map("document_version_id") @db.Uuid
  documentType    DocumentType @map("document_type")
  role            String       @default("primary")
  order           Int          @default(0)

  goldenSample    GoldenSample    @relation(fields: [goldenSampleId], references: [id], onDelete: Cascade)
  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)

  @@index([goldenSampleId])
  @@map("golden_sample_documents")
}

model GoldenSampleStageStatus {
  id              String             @id @default(uuid()) @db.Uuid
  goldenSampleId  String             @map("golden_sample_id") @db.Uuid
  stage           String
  status          GoldenStageStatus  @default(draft)
  expectedResults Json               @default("{}") @map("expected_results") @db.JsonB
  reviewComment   String?            @map("review_comment")
  reviewedById    String?            @map("reviewed_by_id") @db.Uuid
  approvedById    String?            @map("approved_by_id") @db.Uuid
  reviewedAt      DateTime?          @map("reviewed_at")
  approvedAt      DateTime?          @map("approved_at")

  goldenSample GoldenSample @relation(fields: [goldenSampleId], references: [id], onDelete: Cascade)
  reviewedBy   User?        @relation("StageReviewer", fields: [reviewedById], references: [id])
  approvedBy   User?        @relation("StageApprover", fields: [approvedById], references: [id])

  @@unique([goldenSampleId, stage])
  @@map("golden_sample_stage_statuses")
}

enum GoldenStageStatus {
  draft
  in_review
  approved
}

// ─── Evaluation ─────────────────────────────────────────────

model EvaluationRun {
  id               String              @id @default(uuid()) @db.Uuid
  tenantId         String              @map("tenant_id") @db.Uuid
  name             String?
  type             EvaluationRunType
  status           EvaluationRunStatus @default(queued)
  ruleSetVersionId String?             @map("rule_set_version_id") @db.Uuid
  llmConfigId      String?             @map("llm_config_id") @db.Uuid
  contextStrategy  ContextStrategy?    @map("context_strategy_override")
  chunkSizeChars   Int?                @map("chunk_size_chars_override")

  metrics        Json    @default("{}") @db.JsonB
  cost           Float?
  durationMs     Int?    @map("duration_ms")
  totalSamples   Int     @default(0) @map("total_samples")
  passedSamples  Int     @default(0) @map("passed_samples")
  failedSamples  Int     @default(0) @map("failed_samples")
  factCoverage   Float?  @map("fact_coverage")

  comparedToRunId String? @map("compared_to_run_id") @db.Uuid
  delta           Json?   @db.JsonB

  createdById String   @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  ruleSetVersion RuleSetVersion?   @relation(fields: [ruleSetVersionId], references: [id])
  llmConfig      LlmConfig?        @relation(fields: [llmConfigId], references: [id])
  comparedToRun  EvaluationRun?    @relation("EvalComparison", fields: [comparedToRunId], references: [id])
  comparedByRuns EvaluationRun[]   @relation("EvalComparison")
  createdBy      User              @relation(fields: [createdById], references: [id])
  results        EvaluationResult[]

  @@index([tenantId])
  @@map("evaluation_runs")
}

enum EvaluationRunType {
  single
  batch
  llm_comparison
  context_window_test
}

enum EvaluationRunStatus {
  queued
  running
  completed
  failed
}

model EvaluationResult {
  id              String               @id @default(uuid()) @db.Uuid
  evaluationRunId String               @map("evaluation_run_id") @db.Uuid
  goldenSampleId  String               @map("golden_sample_id") @db.Uuid
  stage           String
  status          EvaluationResultStatus @default(pending)

  expected  Json  @default("{}") @db.JsonB
  actual    Json  @default("{}") @db.JsonB
  diff      Json  @default("{}") @db.JsonB

  algoResult Json?    @map("algo_result") @db.JsonB
  llmResult  Json?    @map("llm_result") @db.JsonB
  agreement  Boolean? @map("algo_llm_agreement")

  precision  Float?
  recall     Float?
  f1         Float?
  latencyMs  Int?     @map("latency_ms")
  tokenCost  Float?   @map("token_cost")

  coverageByFactKey Json? @map("coverage_by_fact_key") @db.JsonB

  evaluationRun EvaluationRun @relation(fields: [evaluationRunId], references: [id], onDelete: Cascade)
  goldenSample  GoldenSample  @relation(fields: [goldenSampleId], references: [id], onDelete: Cascade)

  @@index([evaluationRunId])
  @@index([goldenSampleId])
  @@map("evaluation_results")
}

enum EvaluationResultStatus {
  pending
  pass
  fail
  error
  skipped
}

// ─── Correction Records & Recommendations ───────────────────

model CorrectionRecord {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  userRole        String   @map("user_role")
  documentVersionId String @map("document_version_id") @db.Uuid
  stage           String
  entityType      String   @map("entity_type")
  entityId        String   @map("entity_id") @db.Uuid

  originalValue  Json @map("original_value") @db.JsonB
  correctedValue Json @map("corrected_value") @db.JsonB
  context        Json @default("{}") @db.JsonB

  isProcessed      Boolean  @default(false) @map("is_processed")
  recommendationId String?  @map("recommendation_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  user             User                      @relation(fields: [userId], references: [id])
  documentVersion  DocumentVersion           @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  recommendation   CorrectionRecommendation? @relation(fields: [recommendationId], references: [id])

  @@index([tenantId])
  @@index([stage])
  @@index([isProcessed])
  @@map("correction_records")
}

model CorrectionRecommendation {
  id              String                       @id @default(uuid()) @db.Uuid
  tenantId        String                       @map("tenant_id") @db.Uuid
  stage           String
  pattern         String
  frequency       Int                          @default(0)
  suggestedChange String                       @map("suggested_change")
  affectedRuleId  String?                      @map("affected_rule_id") @db.Uuid
  status          CorrectionRecommendationStatus @default(pending)
  reviewedById    String?                      @map("reviewed_by_id") @db.Uuid
  reviewedAt      DateTime?                    @map("reviewed_at")
  comment         String?
  createdAt       DateTime                     @default(now()) @map("created_at")

  reviewedBy  User?              @relation("RecommendationReviewer", fields: [reviewedById], references: [id])
  corrections CorrectionRecord[]

  @@index([tenantId])
  @@index([status])
  @@map("correction_recommendations")
}

enum CorrectionRecommendationStatus {
  pending
  accepted
  rejected
  implemented
}

// ─── Approval Workflow ──────────────────────────────────────

model ApprovalRequest {
  id            String              @id @default(uuid()) @db.Uuid
  tenantId      String              @map("tenant_id") @db.Uuid
  type          ApprovalType
  status        ApprovalStatus      @default(pending)
  requestedById String              @map("requested_by_id") @db.Uuid
  reviewedById  String?             @map("reviewed_by_id") @db.Uuid

  title       String
  description String
  context     Json    @default("{}") @db.JsonB

  entityType String @map("entity_type")
  entityId   String @map("entity_id")

  comment     String?
  requestedAt DateTime  @default(now()) @map("requested_at")
  reviewedAt  DateTime? @map("reviewed_at")

  requestedBy User  @relation("ApprovalRequester", fields: [requestedById], references: [id])
  reviewedBy  User? @relation("ApprovalReviewer", fields: [reviewedById], references: [id])

  @@index([tenantId])
  @@index([status])
  @@map("approval_requests")
}

enum ApprovalType {
  rule_change
  prompt_change
  golden_sample_approval
  verdict_approval
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

// Sprint 5.1: utверждённые экспертом примеры классификации.
// Используются как few-shot inject в LLM Check (Sprint 5.2) — top-K похожих
// (по standardSection или эмбеддингу) подмешиваются в систем-промпт.
//
// Создаются обычно из реального quick-fix flow в diff overlay: «принять как
// эталонный пример» → запись с title/parentPath/zone сохраняется. Также
// можно вручную создать через UI /few-shots в rule-admin.
model ClassificationFewShot {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  // Заголовок секции — главный матчинг ключ для similarity.
  title           String
  // Иерархический контекст: путь parent-titles от корня до этой секции.
  // Помогает LLM различать дубликаты titles в разных частях документа.
  parentPath      String?  @map("parent_path")
  // Опциональный preview содержимого (до 500 chars) — расширяет контекст.
  contentPreview  String?  @map("content_preview")
  // Правильная zone (canonical key из taxonomy).
  standardSection String   @map("standard_section")
  // Объяснение почему именно эта zone — добавляется в промпт «по причине».
  reason          String?
  // Soft-delete: false → не подмешивается в промпт, но история сохраняется.
  isActive        Boolean  @default(true) @map("is_active")

  // Опциональная связь с исходной секцией (для traceability).
  sourceSectionId String?  @map("source_section_id") @db.Uuid

  createdById     String   @map("created_by_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("ClassificationFewShotCreator", fields: [createdById], references: [id])

  @@index([tenantId, isActive])
  @@index([tenantId, standardSection])
  @@map("classification_few_shots")
}
