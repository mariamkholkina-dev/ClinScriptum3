generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant ────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  plan      Plan     @default(basic)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users   User[]
  studies Study[]

  @@map("tenants")
}

enum Plan {
  basic
  extended
}

// ─── Users & Auth ────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         UserRole @default(writer)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens  RefreshToken[]
  findingReviews FindingReview[]

  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  writer
  qc_operator
  findings_reviewer
  rule_admin
  tenant_admin
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Studies & Documents ─────────────────────────────────────

model Study {
  id        String     @id @default(uuid()) @db.Uuid
  tenantId  String     @map("tenant_id") @db.Uuid
  title     String
  phase     StudyPhase @default(unknown)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents      Document[]
  processingRuns ProcessingRun[]

  @@index([tenantId])
  @@map("studies")
}

enum StudyPhase {
  I
  II
  III
  IV
  I_II    @map("I/II")
  II_III  @map("II/III")
  unknown
}

model Document {
  id        String       @id @default(uuid()) @db.Uuid
  studyId   String       @map("study_id") @db.Uuid
  type      DocumentType
  title     String
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  study    Study             @relation(fields: [studyId], references: [id], onDelete: Cascade)
  versions DocumentVersion[]

  @@index([studyId])
  @@map("documents")
}

enum DocumentType {
  protocol
  icf
  ib
  csr
}

model DocumentVersion {
  id            String                @id @default(uuid()) @db.Uuid
  documentId    String                @map("document_id") @db.Uuid
  versionNumber Int                   @map("version_number")
  versionLabel  String?               @map("version_label")
  fileUrl       String                @map("file_url")
  status        DocumentVersionStatus @default(uploading)
  isCurrent     Boolean               @default(false) @map("is_current")
  digitalTwin   Json?                 @map("digital_twin") @db.JsonB
  createdAt     DateTime              @default(now()) @map("created_at")

  document        Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sections        Section[]
  facts           Fact[]
  findings        Finding[]
  processingRuns  ProcessingRun[]
  soaTables       SoaTable[]
  generatedDocs   GeneratedDoc[]
  tuningSessions  TuningSession[]
  findingReviews  FindingReview[]

  @@unique([documentId, versionNumber])
  @@index([documentId])
  @@map("document_versions")
}

enum DocumentVersionStatus {
  uploading
  parsing
  classifying_sections
  extracting_facts
  detecting_soa
  ready
  intra_audit
  inter_audit
  impact_assessment
  parsed
  error
}

// ─── Sections & Content ──────────────────────────────────────

model Section {
  id              String        @id @default(uuid()) @db.Uuid
  docVersionId    String        @map("doc_version_id") @db.Uuid
  title           String
  standardSection String?       @map("standard_section")
  confidence      Float         @default(0)
  classifiedBy    String?       @map("classified_by")
  algoSection     String?       @map("algo_section")
  algoConfidence  Float         @default(0) @map("algo_confidence")
  llmSection      String?       @map("llm_section")
  llmConfidence   Float         @default(0) @map("llm_confidence")
  level           Int
  order           Int
  status          SectionStatus @default(not_validated)
  sourceAnchor    Json          @map("source_anchor") @db.JsonB

  docVersion    DocumentVersion @relation(fields: [docVersionId], references: [id], onDelete: Cascade)
  contentBlocks ContentBlock[]

  @@index([docVersionId])
  @@map("sections")
}

enum SectionStatus {
  validated
  not_validated
  requires_rework
}

model ContentBlock {
  id           String           @id @default(uuid()) @db.Uuid
  sectionId    String           @map("section_id") @db.Uuid
  type         ContentBlockType
  content      String
  rawHtml      String?          @map("raw_html")
  order        Int
  sourceAnchor Json             @map("source_anchor") @db.JsonB

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@map("content_blocks")
}

enum ContentBlockType {
  paragraph
  table
  table_cell
  footnote
  list
  image
}

// ─── Facts ───────────────────────────────────────────────────

model Fact {
  id               String     @id @default(uuid()) @db.Uuid
  docVersionId     String     @map("doc_version_id") @db.Uuid
  factKey          String     @map("fact_key")
  factCategory     String     @map("fact_category")
  description      String     @default("")
  value            String
  manualValue      String?    @map("manual_value")
  confidence       Float      @default(0)
  factClass        FactClass  @map("fact_class")
  sources          Json       @db.JsonB
  hasContradiction Boolean    @default(false) @map("has_contradiction")
  status           FactStatus @default(extracted)

  docVersion DocumentVersion @relation(fields: [docVersionId], references: [id], onDelete: Cascade)

  @@index([docVersionId])
  @@map("facts")
}

enum FactClass {
  general
  phase_specific
}

enum FactStatus {
  extracted
  verified
  validated
  deferred
  not_found
  rejected
}

// ─── Findings ────────────────────────────────────────────────

model Finding {
  id              String         @id @default(uuid()) @db.Uuid
  docVersionId    String         @map("doc_version_id") @db.Uuid
  type            FindingType
  description     String
  suggestion      String?
  sourceRef       Json           @map("source_ref") @db.JsonB
  status          FindingStatus  @default(pending)
  severity        AuditSeverity?
  auditCategory   String?        @map("audit_category")
  issueType       String?        @map("issue_type")
  issueFamily     String?        @map("issue_family")
  anchorZone      String?        @map("anchor_zone")
  targetZone      String?        @map("target_zone")
  qaVerified       Boolean        @default(false) @map("qa_verified")
  hiddenByReviewer Boolean        @default(false) @map("hidden_by_reviewer")
  originalSeverity AuditSeverity? @map("original_severity")
  reviewerNote     String?        @map("reviewer_note")
  extraAttributes  Json           @default("{}") @map("extra_attributes") @db.JsonB
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  docVersion DocumentVersion @relation(fields: [docVersionId], references: [id], onDelete: Cascade)

  @@index([docVersionId])
  @@index([docVersionId, type])
  @@map("findings")
}

enum FindingType {
  editorial
  semantic
  intra_audit
  inter_audit
}

enum FindingStatus {
  pending
  confirmed
  rejected
  resolved
  false_positive
}

enum AuditSeverity {
  critical
  high
  medium
  low
  info
}

// ─── Processing Pipeline ─────────────────────────────────────

model ProcessingRun {
  id               String              @id @default(uuid()) @db.Uuid
  studyId          String              @map("study_id") @db.Uuid
  docVersionId     String              @map("doc_version_id") @db.Uuid
  type             ProcessingRunType
  status           ProcessingRunStatus @default(queued)
  ruleSetVersionId String?             @map("rule_set_version_id") @db.Uuid
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  study          Study            @relation(fields: [studyId], references: [id], onDelete: Cascade)
  docVersion     DocumentVersion  @relation(fields: [docVersionId], references: [id], onDelete: Cascade)
  ruleSetVersion RuleSetVersion?  @relation(fields: [ruleSetVersionId], references: [id])
  steps          ProcessingStep[]

  @@index([studyId])
  @@index([docVersionId])
  @@map("processing_runs")
}

enum ProcessingRunType {
  section_classification
  fact_extraction
  soa_detection
  intra_doc_audit
  inter_doc_audit
  icf_generation
  csr_generation
  version_comparison
}

enum ProcessingRunStatus {
  queued
  running
  completed
  failed
}

model ProcessingStep {
  id              String               @id @default(uuid()) @db.Uuid
  processingRunId String               @map("processing_run_id") @db.Uuid
  level           PipelineLevel
  status          ProcessingStepStatus @default(pending)
  result          Json?                @db.JsonB
  startedAt       DateTime?            @map("started_at")
  completedAt     DateTime?            @map("completed_at")

  processingRun ProcessingRun @relation(fields: [processingRunId], references: [id], onDelete: Cascade)

  @@index([processingRunId])
  @@map("processing_steps")
}

enum PipelineLevel {
  deterministic
  llm_check
  llm_qa
  operator_review
  user_validation
}

enum ProcessingStepStatus {
  pending
  running
  completed
  skipped
  failed
}

// ─── SOA (Schedule of Activities) ────────────────────────

model SoaTable {
  id            String    @id @default(uuid()) @db.Uuid
  docVersionId  String    @map("doc_version_id") @db.Uuid
  sourceBlockId String?   @map("source_block_id") @db.Uuid
  title         String    @default("")
  soaScore      Float     @default(0) @map("soa_score")
  status        SoaStatus @default(detected)
  headerData    Json      @map("header_data") @db.JsonB
  rawMatrix     Json      @map("raw_matrix") @db.JsonB
  footnotes     Json      @default("[]") @db.JsonB
  createdAt     DateTime  @default(now()) @map("created_at")

  docVersion DocumentVersion @relation(fields: [docVersionId], references: [id], onDelete: Cascade)
  cells      SoaCell[]

  @@index([docVersionId])
  @@map("soa_tables")
}

model SoaCell {
  id              String  @id @default(uuid()) @db.Uuid
  soaTableId      String  @map("soa_table_id") @db.Uuid
  rowIndex        Int     @map("row_index")
  colIndex        Int     @map("col_index")
  procedureName   String  @map("procedure_name")
  visitName       String  @map("visit_name")
  rawValue        String  @default("") @map("raw_value")
  normalizedValue String  @default("") @map("normalized_value")
  manualValue     String? @map("manual_value")
  confidence      Float   @default(1.0)

  soaTable SoaTable @relation(fields: [soaTableId], references: [id], onDelete: Cascade)

  @@unique([soaTableId, rowIndex, colIndex])
  @@index([soaTableId])
  @@map("soa_cells")
}

enum SoaStatus {
  detected
  validated
}

// ─── Rule Sets ───────────────────────────────────────────────

model RuleSet {
  id        String      @id @default(uuid()) @db.Uuid
  tenantId  String?     @map("tenant_id") @db.Uuid
  name      String
  type      RuleSetType
  createdAt DateTime    @default(now()) @map("created_at")

  versions RuleSetVersion[]

  @@map("rule_sets")
}

enum RuleSetType {
  section_classification
  fact_extraction
  soa_identification
  audit
}

model RuleSetVersion {
  id        String   @id @default(uuid()) @db.Uuid
  ruleSetId String   @map("rule_set_id") @db.Uuid
  version   Int
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  ruleSet        RuleSet         @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)
  rules          Rule[]
  processingRuns ProcessingRun[]

  @@unique([ruleSetId, version])
  @@map("rule_set_versions")
}

model Rule {
  id               String @id @default(uuid()) @db.Uuid
  ruleSetVersionId String @map("rule_set_version_id") @db.Uuid
  name             String
  pattern          String
  config           Json   @default("{}") @db.JsonB

  ruleSetVersion RuleSetVersion @relation(fields: [ruleSetVersionId], references: [id], onDelete: Cascade)

  @@index([ruleSetVersionId])
  @@map("rules")
}

// ─── Document Templates ───────────────────────────────────────

model DocTemplate {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @map("tenant_id") @db.Uuid
  name      String
  docType   DocumentType @map("doc_type")
  sections  Json         @db.JsonB
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("doc_templates")
}

// ─── Generated Documents ──────────────────────────────────────

model GeneratedDoc {
  id                String             @id @default(uuid()) @db.Uuid
  protocolVersionId String             @map("protocol_version_id") @db.Uuid
  templateId        String?            @map("template_id") @db.Uuid
  docType           DocumentType       @map("doc_type")
  status            GeneratedDocStatus @default(generating)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  protocolVersion DocumentVersion       @relation(fields: [protocolVersionId], references: [id], onDelete: Cascade)
  sections        GeneratedDocSection[]
  tuningSessions  TuningSession[]

  @@index([protocolVersionId])
  @@map("generated_docs")
}

enum GeneratedDocStatus {
  generating
  qa_checking
  completed
  failed
}

model GeneratedDocSection {
  id              String                    @id @default(uuid()) @db.Uuid
  generatedDocId  String                    @map("generated_doc_id") @db.Uuid
  title           String
  standardSection String?                   @map("standard_section")
  order           Int
  content         String                    @default("")
  status          GeneratedDocSectionStatus @default(pending)
  qaFindings      Json                      @default("[]") @map("qa_findings") @db.JsonB

  generatedDoc GeneratedDoc @relation(fields: [generatedDocId], references: [id], onDelete: Cascade)

  @@index([generatedDocId])
  @@map("generated_doc_sections")
}

enum GeneratedDocSectionStatus {
  pending
  generating
  qa_checking
  completed
  skipped
  failed
}

// ─── Finding Reviews ─────────────────────────────────────────

model FindingReview {
  id                String              @id @default(uuid()) @db.Uuid
  tenantId          String              @map("tenant_id") @db.Uuid
  docVersionId      String              @map("doc_version_id") @db.Uuid
  auditType         FindingType         @map("audit_type")
  protocolVersionId String?             @map("protocol_version_id") @db.Uuid
  reviewerId        String?             @map("reviewer_id") @db.Uuid
  status            FindingReviewStatus @default(pending)
  createdAt         DateTime            @default(now()) @map("created_at")
  publishedAt       DateTime?           @map("published_at")

  docVersion DocumentVersion @relation(fields: [docVersionId], references: [id], onDelete: Cascade)
  reviewer   User?           @relation(fields: [reviewerId], references: [id])
  logs       FindingReviewLog[]

  @@unique([docVersionId, auditType])
  @@index([tenantId])
  @@index([status])
  @@map("finding_reviews")
}

enum FindingReviewStatus {
  pending
  in_review
  published
}

model FindingReviewLog {
  id            String   @id @default(uuid()) @db.Uuid
  reviewId      String   @map("review_id") @db.Uuid
  findingId     String   @map("finding_id") @db.Uuid
  reviewerId    String   @map("reviewer_id") @db.Uuid
  action        String
  previousValue String?  @map("previous_value")
  newValue      String?  @map("new_value")
  createdAt     DateTime @default(now()) @map("created_at")

  review FindingReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([findingId])
  @@map("finding_review_logs")
}

// ─── Word Add-in Sessions ────────────────────────────────────

model WordSession {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  context   Json     @db.JsonB
  exchanged Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("word_sessions")
}

// ─── Quality Tuning ──────────────────────────────────────────

model TuningSession {
  id           String              @id @default(uuid()) @db.Uuid
  tenantId     String              @map("tenant_id") @db.Uuid
  userId       String              @map("user_id") @db.Uuid
  docVersionId String              @map("doc_version_id") @db.Uuid
  type         TuningType
  status       TuningSessionStatus @default(processing)
  isGoldenSet  Boolean             @default(false) @map("is_golden_set")
  stats        Json                @default("{}") @db.JsonB
  createdAt    DateTime            @default(now()) @map("created_at")
  completedAt  DateTime?           @map("completed_at")

  generatedDocId String?  @map("generated_doc_id") @db.Uuid

  docVersion         DocumentVersion    @relation(fields: [docVersionId], references: [id], onDelete: Cascade)
  generatedDoc       GeneratedDoc?      @relation(fields: [generatedDocId], references: [id], onDelete: SetNull)
  sectionVerdicts    SectionVerdict[]
  factVerdicts       FactVerdict[]
  soaVerdicts        SoaVerdict[]
  generationVerdicts GenerationVerdict[]

  @@index([tenantId])
  @@index([docVersionId])
  @@map("tuning_sessions")
}

enum TuningType {
  section_classification
  fact_extraction
  soa_detection
  icf_generation
}

enum TuningSessionStatus {
  processing
  pending_review
  in_review
  completed
}

model SectionVerdict {
  id                String    @id @default(uuid()) @db.Uuid
  tuningSessionId   String    @map("tuning_session_id") @db.Uuid
  sectionId         String    @map("section_id") @db.Uuid
  algoResult        String?   @map("algo_result")
  algoConfidence    Float     @default(0) @map("algo_confidence")
  llmResult         String?   @map("llm_result")
  llmConfidence     Float     @default(0) @map("llm_confidence")
  auditorChoice     String?   @map("auditor_choice")
  auditorAgreedWith String?   @map("auditor_agreed_with")
  comment           String?
  reviewedAt        DateTime? @map("reviewed_at")

  tuningSession TuningSession @relation(fields: [tuningSessionId], references: [id], onDelete: Cascade)

  @@index([tuningSessionId])
  @@map("section_verdicts")
}

model FactVerdict {
  id              String    @id @default(uuid()) @db.Uuid
  tuningSessionId String    @map("tuning_session_id") @db.Uuid
  factId          String?   @map("fact_id") @db.Uuid
  factKey         String    @map("fact_key")
  llmValue        String?   @map("llm_value")
  llmConfidence   Float     @default(0) @map("llm_confidence")
  isCorrect       Boolean?  @map("is_correct")
  auditorValue    String?   @map("auditor_value")
  comment         String?
  reviewedAt      DateTime? @map("reviewed_at")

  tuningSession TuningSession @relation(fields: [tuningSessionId], references: [id], onDelete: Cascade)

  @@index([tuningSessionId])
  @@map("fact_verdicts")
}

model SoaVerdict {
  id                 String    @id @default(uuid()) @db.Uuid
  tuningSessionId    String    @map("tuning_session_id") @db.Uuid
  soaTableId         String?   @map("soa_table_id") @db.Uuid
  isCorrectDetection Boolean?  @map("is_correct_detection")
  missedTables       Json      @default("[]") @db.JsonB
  falsePositives     Json      @default("[]") @db.JsonB
  cellVerdicts       Json      @default("[]") @db.JsonB
  comment            String?
  reviewedAt         DateTime? @map("reviewed_at")

  tuningSession TuningSession @relation(fields: [tuningSessionId], references: [id], onDelete: Cascade)

  @@index([tuningSessionId])
  @@map("soa_verdicts")
}

model GenerationVerdict {
  id                    String    @id @default(uuid()) @db.Uuid
  tuningSessionId       String    @map("tuning_session_id") @db.Uuid
  generatedDocSectionId String    @map("generated_doc_section_id") @db.Uuid
  sectionTitle          String    @default("") @map("section_title")
  standardSection       String?   @map("standard_section")
  rating                Int       @default(0)
  comment               String?
  reviewedAt            DateTime? @map("reviewed_at")

  tuningSession TuningSession @relation(fields: [tuningSessionId], references: [id], onDelete: Cascade)

  @@index([tuningSessionId])
  @@map("generation_verdicts")
}
