# Template for /opt/clinscriptum/.env on the dev server.
# Copy to .env and fill secrets. NEVER commit the real .env.
#
#   cp .env.production.example .env
#   chmod 600 .env

# ─── Node ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── Postgres (used by api/workers; service hostname = "postgres") ──────
POSTGRES_DB=clinscriptum
POSTGRES_USER=clinscriptum
POSTGRES_PASSWORD=__GENERATE_STRONG_PASSWORD__
DATABASE_URL=postgresql://clinscriptum:__GENERATE_STRONG_PASSWORD__@postgres:5432/clinscriptum

# ─── Redis (service hostname = "redis") ─────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Auth ───────────────────────────────────────────────────────────────
# openssl rand -hex 64
JWT_SECRET=__REPLACE_WITH_64_BYTE_HEX__
JWT_EXPIRES_IN=24h

# ─── CORS / public URLs ─────────────────────────────────────────────────
CORS_ORIGIN=https://app.dev.clinscriptum.ru,https://admin.dev.clinscriptum.ru
NEXT_PUBLIC_API_URL=https://api.dev.clinscriptum.ru/trpc
NEXT_PUBLIC_RULE_ADMIN_PORT=3002

# ─── Storage (MinIO; service hostname = "minio") ────────────────────────
STORAGE_TYPE=s3
MINIO_ROOT_USER=clinscriptum
MINIO_ROOT_PASSWORD=__GENERATE_STRONG_PASSWORD__
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=clinscriptum-dev
S3_ACCESS_KEY_ID=clinscriptum
S3_SECRET_ACCESS_KEY=__SAME_AS_MINIO_ROOT_PASSWORD__
S3_FORCE_PATH_STYLE=true

# ─── LLM (use a SEPARATE dev key with a budget cap) ─────────────────────
LLM_PROVIDER=yandexgpt
LLM_BASE_URL=https://llm.api.cloud.yandex.net
LLM_API_KEY=__DEV_LLM_KEY__
LLM_MODEL=gpt://<folder_id>/qwen3-235b-a22b-fp8/latest

# Per-task max_tokens (overrides — keep defaults from .env.example)
LLM_FACT_EXTRACTION_MAX_TOKENS=16384
LLM_FACT_EXTRACTION_QA_MAX_TOKENS=4096
LLM_INTER_AUDIT_MAX_TOKENS=8192
LLM_INTER_AUDIT_QA_MAX_TOKENS=4096
LLM_GENERATION_MAX_TOKENS=8192
LLM_GENERATION_MODEL_WINDOW_CHARS=12000
LLM_GENERATION_QA_MAX_TOKENS=4096
LLM_GENERATION_QA_WINDOW_CHARS=12000
LLM_SOA_DETECTION_MAX_TOKENS=8192
LLM_SOA_DETECTION_QA_MAX_TOKENS=4096
LLM_FACT_AUDIT_INTRA_MAX_TOKENS=4096
LLM_FACT_AUDIT_INTRA_QA_MAX_TOKENS=2048
LLM_FACT_AUDIT_INTER_MAX_TOKENS=8192
LLM_FACT_AUDIT_INTER_QA_MAX_TOKENS=4096
LLM_IMPACT_ANALYSIS_MAX_TOKENS=8192
LLM_IMPACT_ANALYSIS_QA_MAX_TOKENS=4096
LLM_CHANGE_CLASSIFICATION_MAX_TOKENS=4096
LLM_CHANGE_CLASSIFICATION_QA_MAX_TOKENS=2048
LLM_CORRECTION_RECOMMEND_MAX_TOKENS=8192
