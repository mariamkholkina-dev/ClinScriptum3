FROM node:24-alpine AS base
WORKDIR /app

FROM base AS builder
COPY package.json package-lock.json turbo.json tsconfig.base.json ./
COPY apps/api/package.json apps/api/
COPY apps/rule-admin/package.json apps/rule-admin/
COPY apps/web/package.json apps/web/
COPY apps/word-addin/package.json apps/word-addin/
COPY apps/workers/package.json apps/workers/
COPY packages/db/package.json packages/db/
COPY packages/diff-engine/package.json packages/diff-engine/
COPY packages/doc-parser/package.json packages/doc-parser/
COPY packages/llm-gateway/package.json packages/llm-gateway/
COPY packages/rules-engine/package.json packages/rules-engine/
COPY packages/shared/package.json packages/shared/
COPY packages/ui/package.json packages/ui/

RUN npm install

COPY packages/ packages/
COPY apps/api/ apps/api/
COPY apps/web/ apps/web/

RUN npx prisma generate --schema=packages/db/prisma/schema.prisma

ARG NEXT_PUBLIC_API_URL=https://app.clinscriptum.ru/trpc
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_TELEMETRY_DISABLED=1
RUN npx turbo build --filter=@clinscriptum/web

FROM base AS runner
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

EXPOSE 3000
ENV NODE_ENV=production
CMD ["node", "apps/web/server.js"]
