FROM node:24-alpine AS base
WORKDIR /app

FROM base AS builder
COPY package.json package-lock.json turbo.json tsconfig.base.json ./
COPY apps/api/package.json apps/api/
COPY apps/rule-admin/package.json apps/rule-admin/
COPY apps/web/package.json apps/web/
COPY apps/word-addin/package.json apps/word-addin/
COPY apps/workers/package.json apps/workers/
COPY packages/db/package.json packages/db/
COPY packages/diff-engine/package.json packages/diff-engine/
COPY packages/doc-parser/package.json packages/doc-parser/
COPY packages/llm-gateway/package.json packages/llm-gateway/
COPY packages/rules-engine/package.json packages/rules-engine/
COPY packages/shared/package.json packages/shared/
COPY packages/ui/package.json packages/ui/

RUN npm ci

COPY packages/ packages/
COPY apps/workers/ apps/workers/

RUN npx prisma generate --schema=packages/db/prisma/schema.prisma
RUN npx turbo build --filter=@clinscriptum/workers

FROM base AS runner
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages ./packages
COPY --from=builder /app/apps/workers ./apps/workers

ENV NODE_ENV=production
CMD ["node", "apps/workers/dist/index.js"]
