# Local test environment for integration tests.
# Integration tests in `apps/api/src/__tests__/integration/` call cleanupTestData()
# which TRUNCATEs ALL tables — must run on a dedicated test-DB, never on dev.
#
# CI overrides these via `.github/workflows/ci.yml` env block (POSTGRES_DB=clinscriptum_test).
# Dev uses these defaults from a local Postgres docker container.

DATABASE_URL=postgresql://clinscriptum:clinscriptum_dev@localhost:5432/clinscriptum3_test
REDIS_URL=redis://localhost:6379
JWT_SECRET=test-secret-do-not-use-in-prod
NODE_ENV=test
